#include <stdio.h>

int main() {
    int a, b, c;

    // Input three numbers
    printf("Enter three numbers: ");
    scanf("%d %d %d", &a, &b, &c);

    // Find largest using if-else
    if(a >= b && a >= c) {
        printf("Largest number = %d", a);
    }
    else if(b >= a && b >= c) {
        printf("Largest number = %d", b);
    }
    else {
        printf("Largest number = %d", c);
    }

    return 0;
}
