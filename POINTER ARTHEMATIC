#include <stdio.h>

int main() {
    int arr[5] = {10, 20, 30, 40, 50};
    int *ptr;

    ptr = arr;  // Pointer points to first element

    printf("Pointer Arithmetic Demonstration:\n");

    // Accessing elements using pointer
    printf("First element = %d\n", *ptr);
    printf("Second element = %d\n", *(ptr + 1));
    printf("Third element = %d\n", *(ptr + 2));

    // Pointer increment
    ptr++;
    printf("After increment, pointer points to = %d\n", *ptr);

    // Pointer decrement
    ptr--;
    printf("After decrement, pointer points to = %d\n", *ptr);

    return 0;
}
