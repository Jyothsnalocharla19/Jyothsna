#include <stdio.h>

int main() {
    int i;

    printf("Using continue (skip multiples of 3):\n");
    for(i = 1; i <= 10; i++) {
        if(i % 3 == 0)
            continue;   // skips multiples of 3
        printf("%d ", i);
    }

    printf("\n\nUsing break (stop at 7):\n");
    for(i = 1; i <= 10; i++) {
        if(i == 7)
            break;      // stops loop when i = 7
        printf("%d ", i);
    }

    return 0;
}
