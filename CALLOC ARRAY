#include <stdio.h>
#include <stdlib.h>

int main() {
    int *arr1, *arr2, n, i;

    // Input number of elements
    printf("Enter number of elements: ");
    scanf("%d", &n);

    // Dynamic allocation using malloc
    arr1 = (int *)malloc(n * sizeof(int));

    // Dynamic allocation using calloc
    arr2 = (int *)calloc(n, sizeof(int));

    // Check if memory is allocated
    if(arr1 == NULL || arr2 == NULL) {
        printf("Memory allocation failed");
        return 1;
    }

    // Input elements for malloc array
    printf("Enter elements for malloc array:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr1[i]);
    }

    // Display malloc array
    printf("Elements in malloc array:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", arr1[i]);
    }

    // Display calloc array (initially zeros)
    printf("\nElements in calloc array (initialized to 0):\n");
    for(i = 0; i < n; i++) {
        printf("%d ", arr2[i]);
    }

    // Free allocated memory
    free(arr1);
    free(arr2);

    return 0;
}
