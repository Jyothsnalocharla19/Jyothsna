#include <stdio.h>

// Function definition
int sum(int a, int b) {
    return a + b;
}

int main() {
    int x, y, result;

    // Input numbers
    printf("Enter two numbers: ");
    scanf("%d %d", &x, &y);

    // Function call
    result = sum(x, y);

    // Display result
    printf("Sum = %d", result);

    return 0;
}
